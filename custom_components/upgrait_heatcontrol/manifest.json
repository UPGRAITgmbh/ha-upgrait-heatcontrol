{
  "domain": "upgrait_heatcontrol",
  "name": "UPGRAIT HeatControl",
  "codeowners": ["@UPGRAITgmbh"],
  "config_flow": true,
  "documentation": "https://github.com/UPGRAITgmbh/ha-upgrait-heatcontrol",
  "integration_type": "device",
  "iot_class": "local_push",
  "issue_tracker": "https://github.com/UPGRAITgmbh/ha-upgrait-heatcontrol/issues",
  "loggers": ["upgrait_heatcontrol_api"],
  "requirements": ["upgrait-heatcontrol-api==0.2.1"],
  "version": "0.2.0",
  "zeroconf": [
    {
      "type": "_upgrait-hc._tcp.local.",
      "name": "upgrait heatcontrol *",
      "properties": {
        "vendor": "upgrait gmbh",
        "model": "heatcontrol"
      }
    }
  ]
}
